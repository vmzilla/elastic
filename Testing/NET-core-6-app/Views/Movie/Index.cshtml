@model List<MovieTracker.Models.Movie>

<h2>Movie List</h2>
<a href="/Movie/Add">+ Add New Movie</a>
<br/><br/>

@if (Model.Count == 0)
{
    <p>No movies added yet.</p>
}
else
{
    <table border="1" cellpadding="8">
        <tr>
            <th>ID</th>
            <th>Title</th>
            <th>Year</th>
            <th>Genre</th>
        </tr>
        @foreach (var movie in Model)
        {
            <tr>
                <td>@movie.Id</td>
                <td>@movie.Title</td>
                <td>@movie.Year</td>
                <td>@movie.Genre</td>
            </tr>
        }
    </table>
}